{
  "name": "vscode-markdown-annotator",
  "displayName": "Markdown Annotator",
  "description": "Add annotations, highlights and comments to Markdown documents",
  "version": "0.8.0",
  "publisher": "jack-long",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:markdown"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "markdownAnnotator.quickHighlight",
        "title": "⚡ 快速高亮"
      },
      {
        "command": "markdownAnnotator.addHighlight",
        "title": "🎨 选择颜色高亮"
      },
      {
        "command": "markdownAnnotator.addComment",
        "title": "💬 添加注释"
      },
      {
        "command": "markdownAnnotator.listAnnotations",
        "title": "📋 查看所有标注"
      },
      {
        "command": "markdownAnnotator.clearAll",
        "title": "🗑️ 清除当前文件高亮"
      },
      {
        "command": "markdownAnnotator.exportAnnotations",
        "title": "📤 导出并归档标注"
      }
    ],
    "keybindings": [
      {
        "command": "markdownAnnotator.addComment",
        "key": "ctrl+alt+m",
        "mac": "cmd+alt+m",
        "when": "editorLangId == markdown && editorHasSelection"
      },
      {
        "command": "markdownAnnotator.exportAnnotations",
        "key": "ctrl+alt+e",
        "mac": "cmd+alt+e",
        "when": "editorLangId == markdown"
      },
      {
        "command": "markdownAnnotator.quickHighlight",
        "key": "ctrl+alt+h",
        "mac": "cmd+alt+h",
        "when": "editorLangId == markdown && editorHasSelection"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "when": "editorLangId == markdown && editorHasSelection",
          "command": "markdownAnnotator.quickHighlight",
          "group": "9_cutcopypaste@90"
        },
        {
          "when": "editorLangId == markdown && editorHasSelection",
          "command": "markdownAnnotator.addHighlight",
          "group": "9_cutcopypaste@91"
        },
        {
          "when": "editorLangId == markdown && editorHasSelection",
          "command": "markdownAnnotator.addComment",
          "group": "9_cutcopypaste@92"
        },
        {
          "when": "editorLangId == markdown",
          "command": "markdownAnnotator.listAnnotations",
          "group": "9_cutcopypaste@93"
        },
        {
          "when": "editorLangId == markdown",
          "command": "markdownAnnotator.clearAll",
          "group": "9_cutcopypaste@94"
        },
        {
          "when": "editorLangId == markdown",
          "command": "markdownAnnotator.exportAnnotations",
          "group": "9_cutcopypaste@95"
        }
      ]
    },
    "configuration": {
      "title": "Markdown Annotator",
      "properties": {
        "markdownAnnotator.highlightColor": {
          "type": "string",
          "default": "yellow",
          "enum": ["yellow", "green", "blue", "pink", "orange"],
          "enumDescriptions": [
            "黄色 - 一般重点",
            "绿色 - 重要/正确",
            "蓝色 - 信息/参考",
            "粉色 - 警告/注意",
            "橙色 - 待办/问题"
          ],
          "description": "默认高亮颜色"
        }
      }
    }
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.7.1"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jack-Long-2022/vscode-markdown-annotator.git"
  },
  "keywords": ["markdown", "annotation", "highlight", "comment", "note-taking", "ai"],
  "author": "Jack Long",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/Jack-Long-2022/vscode-markdown-annotator/issues"
  },
  "homepage": "https://github.com/Jack-Long-2022/vscode-markdown-annotator#readme"
}
