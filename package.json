{
  "name": "vscode-markdown-annotator",
  "displayName": "Markdown Annotator",
  "description": "Add annotations, highlights and comments to Markdown documents",
  "version": "0.4.0",
  "publisher": "jack-long",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:markdown"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "markdownAnnotator.addHighlight",
        "title": "📝 Markdown Annotator: 添加高亮（选择颜色）"
      },
      {
        "command": "markdownAnnotator.quickHighlight",
        "title": "⚡ Markdown Annotator: 快速高亮（默认颜色）"
      },
      {
        "command": "markdownAnnotator.addComment",
        "title": "💬 Markdown Annotator: 添加注释"
      },
      {
        "command": "markdownAnnotator.listAnnotations",
        "title": "📋 Markdown Annotator: 查看所有标注"
      },
      {
        "command": "markdownAnnotator.clearAll",
        "title": "🗑️ Markdown Annotator: 清除当前文件高亮"
      },
      {
        "command": "markdownAnnotator.exportAnnotations",
        "title": "📤 Markdown Annotator: 导出所有标注"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "when": "editorLangId == markdown",
          "submenu": "markdownAnnotator.submenu",
          "group": "markdown@1"
        }
      ],
      "markdownAnnotator.submenu": [
        {
          "command": "markdownAnnotator.quickHighlight",
          "group": "1_highlight@1"
        },
        {
          "command": "markdownAnnotator.addHighlight",
          "group": "1_highlight@2"
        },
        {
          "command": "markdownAnnotator.addComment",
          "group": "2_comment@1"
        },
        {
          "command": "markdownAnnotator.listAnnotations",
          "group": "3_manage@1"
        },
        {
          "command": "markdownAnnotator.clearAll",
          "group": "3_manage@2"
        },
        {
          "command": "markdownAnnotator.exportAnnotations",
          "group": "3_manage@3"
        }
      ]
    },
    "submenus": [
      {
        "id": "markdownAnnotator.submenu",
        "label": "📝 Markdown 标注"
      }
    ],
    "keybindings": [
      {
        "command": "markdownAnnotator.quickHighlight",
        "key": "alt+h",
        "mac": "alt+h",
        "when": "editorTextFocus && editorLangId == markdown"
      },
      {
        "command": "markdownAnnotator.addHighlight",
        "key": "alt+shift+h",
        "mac": "alt+shift+h",
        "when": "editorTextFocus && editorLangId == markdown"
      },
      {
        "command": "markdownAnnotator.addComment",
        "key": "alt+shift+c",
        "mac": "alt+shift+c",
        "when": "editorTextFocus && editorLangId == markdown"
      },
      {
        "command": "markdownAnnotator.listAnnotations",
        "key": "alt+l",
        "mac": "alt+l",
        "when": "editorTextFocus && editorLangId == markdown"
      },
      {
        "command": "markdownAnnotator.clearAll",
        "key": "alt+shift+d",
        "mac": "alt+shift+d",
        "when": "editorTextFocus && editorLangId == markdown"
      },
      {
        "command": "markdownAnnotator.exportAnnotations",
        "key": "alt+shift+e",
        "mac": "alt+shift+e",
        "when": "editorTextFocus && editorLangId == markdown"
      }
    ],
    "configuration": {
      "title": "Markdown Annotator",
      "properties": {
        "markdownAnnotator.highlightColor": {
          "type": "string",
          "default": "yellow",
          "enum": ["yellow", "green", "blue", "pink", "orange"],
          "enumDescriptions": [
            "黄色高亮",
            "绿色高亮",
            "蓝色高亮",
            "粉色高亮",
            "橙色高亮"
          ],
          "description": "默认高亮颜色（用于快速高亮功能）"
        },
        "markdownAnnotator.alwaysShowColorPicker": {
          "type": "boolean",
          "default": true,
          "description": "添加高亮时总是显示颜色选择器（关闭则直接使用默认颜色）"
        },
        "markdownAnnotator.showInPreview": {
          "type": "boolean",
          "default": true,
          "description": "在 Markdown 预览中显示标注（实验性功能）"
        }
      }
    }
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.7.1"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jack-Long-2022/vscode-markdown-annotator.git"
  },
  "keywords": ["markdown", "annotation", "highlight", "comment", "note-taking"],
  "author": "Jack Long",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/Jack-Long-2022/vscode-markdown-annotator/issues"
  },
  "homepage": "https://github.com/Jack-Long-2022/vscode-markdown-annotator#readme"
}
